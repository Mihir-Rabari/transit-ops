datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Company {
  id        String    @id @default(uuid())
  name      String
  users     User[]
  vehicles  Vehicle[]
  drivers   Driver[]
  trips     Trip[]
  createdAt DateTime  @default(now())
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  name          String
  role          Role     // ADMIN, FLEET_MANAGER, DRIVER, SAFETY_OFFICER, FINANCIAL_ANALYST
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  driver        Driver?
  createdAt     DateTime @default(now())
}

enum Role {
  ADMIN
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

model Vehicle {
  id                String   @id @default(uuid())
  registrationNumber String  @unique
  name              String
  type              String
  maxLoadCapacityKg Float
  odometer          Float    @default(0)
  acquisitionCost   Float
  status            VehicleStatus @default(AVAILABLE)
  region            String?
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  trips             Trip[]
  maintenanceLogs   MaintenanceLog[]
  fuelLogs          FuelLog[]
  expenses          Expense[]
  documents         VehicleDocument[]
  createdAt         DateTime @default(now())
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

model Driver {
  id                String   @id @default(uuid())
  name              String
  licenseNumber     String   @unique
  licenseCategory   String
  licenseExpiryDate DateTime
  contactNumber     String
  safetyScore       Float    @default(100)
  status            DriverStatus @default(AVAILABLE)
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  trips             Trip[]
  userId            String?  @unique
  user              User?    @relation(fields: [userId], references: [id])
  documents         DriverDocument[]
  createdAt         DateTime @default(now())
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

model Trip {
  id              String   @id @default(uuid())
  source          String
  destination     String
  vehicleId       String
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  driverId        String
  driver          Driver   @relation(fields: [driverId], references: [id])
  cargoWeightKg   Float
  plannedDistanceKm Float
  actualDistanceKm  Float?
  fuelConsumedL     Float?
  status          TripStatus @default(DRAFT)
  dispatchedAt    DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  documents       TripDocument[]
  createdAt       DateTime @default(now())
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

model MaintenanceLog {
  id          String   @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  description String
  cost        Float    @default(0)
  status      MaintenanceStatus @default(ACTIVE)
  openedAt    DateTime @default(now())
  closedAt    DateTime?
}

enum MaintenanceStatus {
  ACTIVE
  CLOSED
}

model FuelLog {
  id         String   @id @default(uuid())
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
  liters     Float
  cost       Float
  date       DateTime @default(now())
}

model Expense {
  id         String   @id @default(uuid())
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
  type       String   // toll, maintenance, misc
  amount     Float
  date       DateTime @default(now())
}

model VehicleDocument {
  id          String   @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  title       String
  docType     String   // e.g. Insurance, Registration, Permit
  expiryDate  DateTime
  createdAt   DateTime @default(now())
}

model DriverDocument {
  id          String   @id @default(uuid())
  driverId    String
  driver      Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  title       String
  docType     String   // e.g. License, Medical, Cert
  s3Key       String
  s3Url       String
  expiryDate  DateTime?
  createdAt   DateTime @default(now())
}

model TripDocument {
  id          String   @id @default(uuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  title       String
  docType     String   // e.g. BOL, POD
  s3Key       String
  s3Url       String
  createdAt   DateTime @default(now())
}
